DATABASE_URL=postgresql://{{ db_user }}:{{ db_password }}@{{ hostvars[groups['db'][0]]['ansible_host'] }}:{{ db_port }}/{{ db_name }}?schema=public
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
PORT={{ app_port }}
NODE_ENV=production
